APP_NAME=stocks-api
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

ADMIN_API_TOKEN=change-me
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/stocks_api
DATABASE_CONNECT_TIMEOUT_SECONDS=5

ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true
ALPACA_REQUEST_TIMEOUT_SECONDS=10
# Alpaca options market data uses https://data.alpaca.markets internally.
AUTO_MIGRATE_ON_STARTUP=
MARKET_CYCLE_SCAN_ENABLED=true
MARKET_CYCLE_RECONCILE_ENABLED=true
MARKET_CYCLE_PREVIEW_ENABLED=false
MARKET_CYCLE_SUBMIT_ENABLED=false

# Global automation safety gates. These apply in addition to strategy-level scanner.submit limits.
TRADING_AUTOMATION_ENABLED=false
AUTO_SUBMIT_REQUIRES_PAPER=true
MAX_AUTO_ORDERS_PER_CYCLE=1
MAX_AUTO_ORDERS_PER_DAY=3
MAX_OPEN_POSITIONS=3
MAX_OPEN_POSITIONS_PER_SYMBOL=1
MAX_CONTRACTS_PER_ORDER=1
MAX_ESTIMATED_PREMIUM_PER_ORDER=250
SCHEDULED_JOBS_ENABLED=false

# Render cron job runner settings.
STOCKS_API_BASE_URL=http://127.0.0.1:8000
JOB_PATH=/api/v1/jobs/market-cycle?scan_limit=100&order_limit=100&fill_page_size=100
JOB_TIMEOUT_SECONDS=90
