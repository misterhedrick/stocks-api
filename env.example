APP_NAME=stocks-api
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# ── Secrets (never commit real values) ──────────────────────────────────────
ADMIN_API_TOKEN=change-me
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/stocks_api
DATABASE_CONNECT_TIMEOUT_SECONDS=5

ALPACA_API_KEY=
ALPACA_API_SECRET=
# ALPACA_PAPER=true keeps every order in the paper-trading sandbox.
# AUTO_SUBMIT_REQUIRES_PAPER=true refuses auto-submit if ALPACA_PAPER is false.
# Never disable either of these for local development.
ALPACA_PAPER=true
ALPACA_REQUEST_TIMEOUT_SECONDS=10
AUTO_MIGRATE_ON_STARTUP=

# ── Market-cycle feature flags ───────────────────────────────────────────────
# Local defaults are conservative: scan and reconcile are on, everything that
# can submit real orders is off. Flip the switches intentionally when testing.
MARKET_CYCLE_SCAN_ENABLED=true
MARKET_CYCLE_RECONCILE_ENABLED=true
MARKET_CYCLE_PREVIEW_ENABLED=false
MARKET_CYCLE_EXIT_ENABLED=false
MARKET_CYCLE_NEWS_ENABLED=false
MARKET_CYCLE_SUBMIT_ENABLED=false
# Per-cycle wall-clock timeout in seconds for each market-cycle phase.
MARKET_CYCLE_PHASE_TIMEOUT_SECONDS=70

# ── News scanner ─────────────────────────────────────────────────────────────
NEWS_REQUEST_TIMEOUT_SECONDS=10
NEWS_MARKET_RSS_FEEDS=https://news.google.com/rss/search?q=stock%20market%20OR%20S%26P%20500%20OR%20Nasdaq%20OR%20Dow%20Jones&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=Federal%20Reserve%20OR%20interest%20rates%20OR%20inflation%20OR%20CPI%20OR%20PPI%20OR%20jobs%20report&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=US%20economy%20OR%20Treasury%20yields%20OR%20dollar%20OR%20recession%20OR%20GDP&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=world%20markets%20OR%20global%20stocks%20OR%20geopolitical%20risk%20OR%20oil%20prices%20OR%20war%20OR%20tariffs&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=earnings%20guidance%20OR%20market%20volatility%20OR%20VIX%20OR%20credit%20markets%20OR%20banking%20sector&hl=en-US&gl=US&ceid=US:en
NEWS_TICKER_RSS_TEMPLATE=https://news.google.com/rss/search?q={symbol}%20stock%20OR%20{symbol}%20options&hl=en-US&gl=US&ceid=US:en

# ── Automation safety gates ──────────────────────────────────────────────────
# TRADING_AUTOMATION_ENABLED is the global kill switch for auto-submit.
# Keep it false locally unless you are intentionally running an automated test.
# AUTO_SUBMIT_REQUIRES_PAPER blocks live-trading accidents; keep it true always.
TRADING_AUTOMATION_ENABLED=false
AUTO_SUBMIT_REQUIRES_PAPER=true

# Order/position limits. Local defaults are tight to prevent accidental runaway.
# See "Monday paper-auto test values" section below for the deployed test config.
MAX_AUTO_ORDERS_PER_CYCLE=1
MAX_AUTO_ORDERS_PER_DAY=3
MAX_OPEN_POSITIONS=3
MAX_OPEN_POSITIONS_PER_SYMBOL=1
MAX_CONTRACTS_PER_ORDER=1
MAX_ESTIMATED_PREMIUM_PER_ORDER=250

# ── Strategy seeding helpers (used by seed scripts, not the app itself) ───────
PAPER_STRATEGY_MIN_CHANGE_PERCENT=0.10
PAPER_STRATEGY_TREND_MIN_CHANGE_PERCENT=0.35
PAPER_STRATEGY_MAX_SPREAD=0.20
PAPER_STRATEGY_MAX_SPREAD_PERCENT=20
PAPER_STRATEGY_PROFIT_TARGET_PERCENT=25
PAPER_STRATEGY_STOP_LOSS_PERCENT=15

# ── Render cron job runner (scripts/run_render_job.py) ───────────────────────
# SCHEDULED_JOBS_ENABLED is checked by the cron runner before calling the API.
# Keep false locally unless you want the runner script to fire against a real URL.
SCHEDULED_JOBS_ENABLED=false
STOCKS_API_BASE_URL=http://127.0.0.1:8000
JOB_PATH=/api/v1/jobs/market-cycle?scan_limit=50&order_limit=100&fill_page_size=100
JOB_TIMEOUT_SECONDS=90
JOB_RETRY_DELAYS_SECONDS=10,30
JOB_SKIP_HTTP_STATUS_CODES=

# ── Monday paper-auto test values (used in render.yaml) ──────────────────────
# render.yaml is intentionally configured for Monday paper-auto testing with
# the settings below. These are NOT the local defaults above — they live in
# render.yaml and are applied by Render at deploy time.
#
# Paper-only safeguards (required, never change):
#   ALPACA_PAPER=true
#   AUTO_SUBMIT_REQUIRES_PAPER=true
#
# Automation intentionally enabled:
#   TRADING_AUTOMATION_ENABLED=true
#   SCHEDULED_JOBS_ENABLED=true
#   MARKET_CYCLE_SCAN_ENABLED=true
#   MARKET_CYCLE_RECONCILE_ENABLED=true
#   MARKET_CYCLE_PREVIEW_ENABLED=true
#   MARKET_CYCLE_EXIT_ENABLED=true
#   MARKET_CYCLE_NEWS_ENABLED=true
#   MARKET_CYCLE_SUBMIT_ENABLED=true
#
# Moderate data-collection limits (balances data richness vs. position noise):
#   MAX_AUTO_ORDERS_PER_CYCLE=3
#   MAX_AUTO_ORDERS_PER_DAY=15
#   MAX_OPEN_POSITIONS=15
#   MAX_OPEN_POSITIONS_PER_SYMBOL=2
#   MAX_CONTRACTS_PER_ORDER=1
#   MAX_ESTIMATED_PREMIUM_PER_ORDER=500
#
# Emergency stops (any one is sufficient):
#   TRADING_AUTOMATION_ENABLED=false   — halt all auto-submit globally
#   MARKET_CYCLE_SUBMIT_ENABLED=false  — halt entry submits, keep scan/reconcile
#   SCHEDULED_JOBS_ENABLED=false       — stop cron execution entirely
#   MARKET_CYCLE_EXIT_ENABLED=false    — pause exit automation only
