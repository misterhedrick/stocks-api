APP_NAME=stocks-api
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Secrets (never commit real values)
ADMIN_API_TOKEN=change-me
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/stocks_api
DATABASE_CONNECT_TIMEOUT_SECONDS=5

ALPACA_API_KEY=
ALPACA_API_SECRET=
# ALPACA_PAPER=true keeps every order in the paper-trading sandbox.
# AUTO_SUBMIT_REQUIRES_PAPER=true refuses auto-submit if ALPACA_PAPER is false.
# Never disable either of these for local development.
ALPACA_PAPER=true
ALPACA_REQUEST_TIMEOUT_SECONDS=10
AUTO_MIGRATE_ON_STARTUP=

# Market-cycle feature flags
# Local defaults are conservative: scan and reconcile are on, everything that
# can submit real orders is off. Flip the switches intentionally when testing.
MARKET_CYCLE_SCAN_ENABLED=true
MARKET_CYCLE_RECONCILE_ENABLED=true
MARKET_CYCLE_PREVIEW_ENABLED=false
MARKET_CYCLE_EXIT_ENABLED=false
MARKET_CYCLE_NEWS_ENABLED=false
MARKET_CYCLE_SUBMIT_ENABLED=false
# Per-cycle wall-clock timeout in seconds for each market-cycle phase.
MARKET_CYCLE_PHASE_TIMEOUT_SECONDS=70

# News scanner
NEWS_REQUEST_TIMEOUT_SECONDS=10
NEWS_MARKET_RSS_FEEDS=https://news.google.com/rss/search?q=stock%20market%20OR%20S%26P%20500%20OR%20Nasdaq%20OR%20Dow%20Jones&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=Federal%20Reserve%20OR%20interest%20rates%20OR%20inflation%20OR%20CPI%20OR%20PPI%20OR%20jobs%20report&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=US%20economy%20OR%20Treasury%20yields%20OR%20dollar%20OR%20recession%20OR%20GDP&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=world%20markets%20OR%20global%20stocks%20OR%20geopolitical%20risk%20OR%20oil%20prices%20OR%20war%20OR%20tariffs&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=earnings%20guidance%20OR%20market%20volatility%20OR%20VIX%20OR%20credit%20markets%20OR%20banking%20sector&hl=en-US&gl=US&ceid=US:en
NEWS_TICKER_RSS_TEMPLATE=https://news.google.com/rss/search?q={symbol}%20stock%20OR%20{symbol}%20options&hl=en-US&gl=US&ceid=US:en

# Automation safety gates
# TRADING_AUTOMATION_ENABLED is the global kill switch for auto-submit.
# Keep it false locally unless you are intentionally running an automated test.
# AUTO_SUBMIT_REQUIRES_PAPER blocks live-trading accidents; keep it true always.
TRADING_AUTOMATION_ENABLED=false
AUTO_SUBMIT_REQUIRES_PAPER=true

# Order/position limits. Local defaults are tight to prevent accidental runaway.
# See "Monday paper-auto test values" section below for the deployed test config.
MAX_AUTO_ORDERS_PER_CYCLE=1
MAX_AUTO_ORDERS_PER_DAY=3
MAX_AUTO_ORDERS_PER_SYMBOL_PER_DAY=5
MAX_OPEN_POSITIONS=3
MAX_OPEN_POSITIONS_PER_SYMBOL=1
MAX_CONTRACTS_PER_ORDER=1
MAX_ESTIMATED_PREMIUM_PER_ORDER=5000

# Strategy seeding helpers (used by seed scripts and strategy templates)
STRATEGY_MIN_CHANGE_PERCENT=0.10
STRATEGY_TREND_MIN_CHANGE_PERCENT=0.25
STRATEGY_MAX_ESTIMATED_NOTIONAL=5000
STRATEGY_MIN_OPEN_INTEREST=50
STRATEGY_MAX_SPREAD=0.35
STRATEGY_MAX_SPREAD_PERCENT=35
STRATEGY_PROFIT_TARGET_PERCENT=25
STRATEGY_STOP_LOSS_PERCENT=10
STRATEGY_STOP_LOSS_MIN_DOLLARS=10
# Post-market review snapshots store the learning report and are pruned
# after this many days during post-market maintenance.
REVIEW_SNAPSHOT_RETENTION_DAYS=45


# Global option-selection safety and diagnostic limits.
OPTIONS_MIN_DTE=7
OPTIONS_TARGET_DTE=14
OPTIONS_MAX_DTE=45
OPTIONS_MIN_OPEN_INTEREST=50
OPTIONS_MAX_CONTRACT_NOTIONAL=5000
OPTIONS_MAX_SPREAD_PCT=0.15
OPTIONS_PREVIEW_MAX_ATTEMPTS=3
OPTIONS_CANDIDATE_LIMIT=100
OPTIONS_DIAGNOSTIC_CANDIDATE_LIMIT=10
OPTIONS_ALLOW_MISSING_OI_SYMBOLS=SPY,QQQ

# Evaluator-backed scanners. Keep SIGNAL_EVALUATORS_ENABLED=true to use the
# normalized evaluator path; individual flags are per-strategy kill switches.
SIGNAL_EVALUATORS_ENABLED=true
MOMENTUM_EVALUATOR_ENABLED=true
MOVING_AVERAGE_EVALUATOR_ENABLED=true
RSI_EVALUATOR_ENABLED=true
MACD_EVALUATOR_ENABLED=true
MEAN_REVERSION_EVALUATOR_ENABLED=true
BREAKOUT_PRICE_THRESHOLD_EVALUATOR_ENABLED=true
VOLUME_CONFIRMED_BREAKOUT_EVALUATOR_ENABLED=true
VOLATILITY_SQUEEZE_EVALUATOR_ENABLED=true
SUPPORT_RESISTANCE_EVALUATOR_ENABLED=true
VWAP_RECLAIM_EVALUATOR_ENABLED=true
OPENING_RANGE_BREAKOUT_EVALUATOR_ENABLED=true
RELATIVE_STRENGTH_EVALUATOR_ENABLED=true
TIME_SERIES_MOMENTUM_EVALUATOR_ENABLED=true
MARKET_REGIME_FILTER_EVALUATOR_ENABLED=true
PAIRS_RELATIVE_VALUE_EVALUATOR_ENABLED=true
OPTIONS_SPREAD_CANDIDATE_EVALUATOR_ENABLED=true

# Entry quality gate. Signals still get recorded, but weak entries are held back
# from auto-submit unless the setup and selected option pass quality checks.
ENTRY_QUALITY_GATE_ENABLED=true
ENTRY_QUALITY_MIN_SCORE=60
ENTRY_QUALITY_FAST_CONFIRMATION_ENABLED=true
ENTRY_QUALITY_DISABLED_AUTO_SUBMIT_SCANNERS=market_regime_filter,pairs_relative_value,options_spread_candidate
ENTRY_QUALITY_MIN_RELATIVE_EDGE_PERCENT=1.0
ENTRY_QUALITY_MIN_MOMENTUM_THRESHOLD_MULTIPLIER=1.8
ENTRY_QUALITY_MIN_BREAKOUT_BUFFER_MULTIPLIER=1.5
ENTRY_QUALITY_MIN_VWAP_DISTANCE_PERCENT=0.25
ENTRY_QUALITY_MIN_AVERAGE_SEPARATION_PERCENT=0.20
ENTRY_QUALITY_MAX_OPTION_SPREAD_PERCENT=25
ENTRY_QUALITY_MIN_OPEN_INTEREST=50
ENTRY_QUALITY_STOP_LOSS_COOLDOWN_MINUTES=120

# Preview profile limits keyed by scanner.preview.preview_profile / scanner.type.
STRATEGY_PREVIEW_PROFILES_ENABLED=true
PREVIEW_PROFILE_PRICE_THRESHOLD_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_PRICE_THRESHOLD_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_PRICE_THRESHOLD_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_PERCENT_CHANGE_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_PERCENT_CHANGE_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_PERCENT_CHANGE_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_MOVING_AVERAGE_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_MOVING_AVERAGE_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_MOVING_AVERAGE_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_TREND_CONFIRMATION_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_TREND_CONFIRMATION_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_TREND_CONFIRMATION_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_MOMENTUM_RATE_OF_CHANGE_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_MOMENTUM_RATE_OF_CHANGE_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_MOMENTUM_RATE_OF_CHANGE_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_RSI_REVERSAL_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_RSI_REVERSAL_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_RSI_REVERSAL_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_MACD_CROSSOVER_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_MACD_CROSSOVER_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_MACD_CROSSOVER_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_MEAN_REVERSION_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_MEAN_REVERSION_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_MEAN_REVERSION_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_BREAKOUT_PRICE_THRESHOLD_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_BREAKOUT_PRICE_THRESHOLD_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_BREAKOUT_PRICE_THRESHOLD_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_VOLUME_CONFIRMED_BREAKOUT_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_VOLUME_CONFIRMED_BREAKOUT_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_VOLUME_CONFIRMED_BREAKOUT_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_VOLATILITY_SQUEEZE_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_VOLATILITY_SQUEEZE_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_VOLATILITY_SQUEEZE_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_SUPPORT_RESISTANCE_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_SUPPORT_RESISTANCE_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_SUPPORT_RESISTANCE_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_VWAP_RECLAIM_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_VWAP_RECLAIM_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_VWAP_RECLAIM_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_OPENING_RANGE_BREAKOUT_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_OPENING_RANGE_BREAKOUT_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_OPENING_RANGE_BREAKOUT_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_RELATIVE_STRENGTH_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_RELATIVE_STRENGTH_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_RELATIVE_STRENGTH_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_TIME_SERIES_MOMENTUM_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_TIME_SERIES_MOMENTUM_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_TIME_SERIES_MOMENTUM_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_MARKET_REGIME_FILTER_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_MARKET_REGIME_FILTER_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_MARKET_REGIME_FILTER_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_PAIRS_RELATIVE_VALUE_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_PAIRS_RELATIVE_VALUE_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_PAIRS_RELATIVE_VALUE_MAX_SPREAD_PERCENT=35
PREVIEW_PROFILE_OPTIONS_SPREAD_CANDIDATE_MIN_OPEN_INTEREST=50
PREVIEW_PROFILE_OPTIONS_SPREAD_CANDIDATE_MAX_ESTIMATED_NOTIONAL=5000
PREVIEW_PROFILE_OPTIONS_SPREAD_CANDIDATE_MAX_SPREAD_PERCENT=35

# Render cron job runner (scripts/run_render_job.py)
# SCHEDULED_JOBS_ENABLED is checked by the cron runner before calling the API.
# Keep false locally unless you want the runner script to fire against a real URL.
SCHEDULED_JOBS_ENABLED=false
STOCKS_API_BASE_URL=http://127.0.0.1:8000
JOB_PATH=/api/v1/jobs/market-entry-cycle?symbol=SPY&scan_limit=100&order_limit=100&fill_page_size=100
JOB_TIMEOUT_SECONDS=90
JOB_RETRY_DELAYS_SECONDS=10,30
JOB_SKIP_HTTP_STATUS_CODES=

# Monday paper-auto test values (used in render.yaml)
# render.yaml is intentionally configured for Monday paper-auto testing with
# the settings below. These are NOT the local defaults above - they live in
# render.yaml and are applied by Render at deploy time.
#
# Paper-trading-only safeguards (required, never change):
#   ALPACA_PAPER=true
#   AUTO_SUBMIT_REQUIRES_PAPER=true
#
# Automation intentionally enabled:
#   TRADING_AUTOMATION_ENABLED=true
#   SCHEDULED_JOBS_ENABLED=true
#   MARKET_CYCLE_SCAN_ENABLED=true
#   MARKET_CYCLE_RECONCILE_ENABLED=true
#   MARKET_CYCLE_PREVIEW_ENABLED=true
#   MARKET_CYCLE_EXIT_ENABLED=true
#   MARKET_CYCLE_NEWS_ENABLED=false
#   MARKET_CYCLE_SUBMIT_ENABLED=true
#   SIGNAL_EVALUATORS_ENABLED=true
#
# Moderate data-collection limits (balances data richness vs. position noise):
#   MAX_AUTO_ORDERS_PER_CYCLE=3
#   MAX_AUTO_ORDERS_PER_DAY=60
#   MAX_AUTO_ORDERS_PER_SYMBOL_PER_DAY=5
#   MAX_OPEN_POSITIONS=30
#   MAX_OPEN_POSITIONS_PER_SYMBOL=3
#   MAX_CONTRACTS_PER_ORDER=1
#   MAX_ESTIMATED_PREMIUM_PER_ORDER=5000
#   STRATEGY_MAX_ESTIMATED_NOTIONAL=5000
#   STRATEGY_MIN_OPEN_INTEREST=50
#
# Emergency stops (any one is sufficient):
#   TRADING_AUTOMATION_ENABLED=false   - halt all auto-submit globally
#   MARKET_CYCLE_SUBMIT_ENABLED=false  - halt entry submits, keep scan/reconcile
#   SCHEDULED_JOBS_ENABLED=false       - stop cron execution entirely
#   MARKET_CYCLE_EXIT_ENABLED=false    - pause exit automation only
